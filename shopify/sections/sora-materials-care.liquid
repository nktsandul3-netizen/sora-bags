{% comment %}
  SÓRA Materials & Care — for Shopify Dawn
  Template: page.sora-care.json
  Assets expected in theme assets/ (or set image URLs in section settings):
    - raffia_texture_closeup.webp
    - white_intrecciato_leather_macro.webp
    - blue_white_silk_scarf.webp
    - minimal_flatlay_sandstone.webp
{% endcomment %}

<section class="sora-care" id="sora-materials-care">
  <div class="sora-care__inner">
    {% if section.settings.heading != blank %}
      <h1 class="sora-care__heading">{{ section.settings.heading }}</h1>
    {% endif %}

    <div class="sora-care__blocks">
      {% for block in section.blocks %}
        {% if block.type == 'content_block' %}
          {% assign image_left = true %}
          {% assign block_index = forloop.index0 %}
          {% if block_index == 1 or block_index == 3 %}
            {% assign image_left = false %}
          {% endif %}

          <article
            class="sora-care__row{% unless image_left %} sora-care__row--reverse{% endunless %}"
            {{ block.shopify_attributes }}
          >
            <div class="sora-care__media">
              {% if block.settings.image != blank %}
                {% assign care_alt = block.settings.image.alt | default: block.settings.title %}
                {{
                  block.settings.image
                  | image_url: width: 1600
                  | image_tag:
                    loading: 'lazy',
                    widths: '400, 600, 800, 1200, 1600',
                    sizes: '(min-width: 990px) 40vw, 100vw',
                    class: 'sora-care__img',
                    alt: care_alt
                }}
              {% elsif block.settings.image_filename != blank %}
                <img
                  class="sora-care__img"
                  src="{{ block.settings.image_filename | asset_url }}"
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                  width="800"
                  height="1000"
                >
              {% endif %}
            </div>

            <div class="sora-care__copy">
              {% if block.settings.title != blank %}
                <h2 class="sora-care__title">{{ block.settings.title }}</h2>
              {% endif %}
              {% if block.settings.text != blank %}
                <div class="sora-care__text rte">{{ block.settings.text }}</div>
              {% endif %}
            </div>
          </article>
        {% endif %}
      {% endfor %}
    </div>

    {% assign faq_blocks = section.blocks | where: 'type', 'faq' %}
    {% if faq_blocks.size > 0 %}
      <div class="sora-care__faq">
        {% if section.settings.faq_heading != blank %}
          <h2 class="sora-care__faq-heading">{{ section.settings.faq_heading }}</h2>
        {% endif %}

        <div class="sora-care__accordion">
          {% for block in faq_blocks %}
            <details class="sora-care__details" {{ block.shopify_attributes }} {% if forloop.first %}open{% endif %}>
              <summary class="sora-care__summary">
                <span>{{ block.settings.question }}</span>
                <span class="sora-care__plus" aria-hidden="true">+</span>
              </summary>
              <div class="sora-care__answer">{{ block.settings.answer }}</div>
            </details>
          {% endfor %}
        </div>
      </div>
    {% endif %}

    {% if section.settings.whatsapp_url != blank %}
      <div class="sora-care__cta">
        <a
          class="sora-care__whatsapp"
          href="{{ section.settings.whatsapp_url }}"
          target="_blank"
          rel="noopener noreferrer"
        >
          {{ section.settings.whatsapp_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .sora-care {
    background: #faf8f5;
    color: #2b2b2b;
    padding: 48px 0 72px;
  }

  .sora-care__inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .sora-care__heading {
    margin: 0 0 48px;
    text-align: center;
    font-size: 32px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    line-height: 1.25;
    color: #2b2b2b;
  }

  .sora-care__blocks {
    display: grid;
    gap: 64px;
  }

  .sora-care__row {
    display: grid;
    gap: 28px;
    align-items: center;
  }

  .sora-care__media {
    aspect-ratio: 4 / 5;
    border-radius: 16px;
    overflow: hidden;
    background: #efebe4;
  }

  .sora-care__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sora-care__title {
    margin: 0 0 16px;
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #2b2b2b;
  }

  .sora-care__text,
  .sora-care__text p,
  .sora-care__answer {
    font-size: 14px;
    line-height: 1.8;
    color: #2b2b2b;
  }

  .sora-care__text p {
    margin: 0 0 1em;
  }

  .sora-care__text p:last-child {
    margin-bottom: 0;
  }

  .sora-care__faq {
    margin-top: 80px;
  }

  .sora-care__faq-heading {
    margin: 0 0 28px;
    text-align: center;
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .sora-care__accordion {
    border-top: 1px solid rgba(43, 43, 43, 0.15);
    border-bottom: 1px solid rgba(43, 43, 43, 0.15);
  }

  .sora-care__details {
    border-bottom: 1px solid rgba(43, 43, 43, 0.15);
  }

  .sora-care__details:last-child {
    border-bottom: 0;
  }

  .sora-care__summary {
    list-style: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 20px 0;
    cursor: pointer;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sora-care__summary::-webkit-details-marker {
    display: none;
  }

  .sora-care__plus {
    font-size: 18px;
    line-height: 1;
    color: rgba(43, 43, 43, 0.7);
    transition: transform 0.2s ease;
  }

  .sora-care__details[open] .sora-care__plus {
    transform: rotate(45deg);
  }

  .sora-care__answer {
    padding: 0 0 20px;
  }

  .sora-care__cta {
    margin-top: 40px;
    text-align: center;
  }

  .sora-care__whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 32px;
    background: #2b2b2b;
    color: #fff;
    text-decoration: none;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .sora-care__whatsapp:hover {
    background: #000;
    color: #fff;
  }

  @media screen and (min-width: 990px) {
    .sora-care {
      padding: 72px 0 96px;
    }

    .sora-care__blocks {
      gap: 96px;
    }

    .sora-care__row {
      grid-template-columns: 1fr 1fr;
      gap: 56px;
    }

    .sora-care__row--reverse .sora-care__media {
      order: 2;
    }

    .sora-care__row--reverse .sora-care__copy {
      order: 1;
    }
  }

  @media screen and (max-width: 989px) {
    .sora-care__heading {
      font-size: 28px;
    }

    .sora-care__row {
      grid-template-columns: 1fr;
    }

    .sora-care__media {
      order: 0;
    }

    .sora-care__copy {
      order: 1;
    }
  }
</style>

{% schema %}
{
  "name": "SÓRA Materials Care",
  "tag": "section",
  "class": "section-sora-materials-care",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Materials and care"
    },
    {
      "type": "text",
      "id": "faq_heading",
      "label": "FAQ heading",
      "default": "FAQ"
    },
    {
      "type": "url",
      "id": "whatsapp_url",
      "label": "WhatsApp URL",
      "default": "https://wa.me/37360066665"
    },
    {
      "type": "text",
      "id": "whatsapp_label",
      "label": "WhatsApp button label",
      "default": "Write on WhatsApp"
    }
  ],
  "blocks": [
    {
      "type": "content_block",
      "name": "Content block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_filename",
          "label": "Asset filename fallback",
          "info": "Used if Image is empty. Example: raffia_texture_closeup.webp"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Material"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Describe the material and how to care for it.</p>"
        }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SÓRA Materials Care",
      "blocks": [
        {
          "type": "content_block",
          "settings": {
            "image_filename": "raffia_texture_closeup.webp",
            "title": "Raffia",
            "text": "<p>Woven raffia is a light natural material for the city and warmer seasons. Keep it away from heavy moisture.</p><p>If wet, gently blot with a soft dry cloth and let dry naturally away from heaters and direct sun.</p>"
          }
        },
        {
          "type": "content_block",
          "settings": {
            "image_filename": "white_intrecciato_leather_macro.webp",
            "title": "Intreccio leather",
            "text": "<p>Natural leather and intreccio weaving keep their grain, softness and shade. Small variations are a sign of a living material.</p><p>Do not machine-wash or soak bags. Clean with a soft cloth and leather care products.</p>"
          }
        },
        {
          "type": "content_block",
          "settings": {
            "image_filename": "blue_white_silk_scarf.webp",
            "title": "Silk / Foulard",
            "text": "<p>Silk scarves add a light accent to a bag or look. Store them away from direct sun to keep the print vivid.</p><p>Prefer gentle dry cleaning or hand wash in cool water with silk detergent.</p>"
          }
        },
        {
          "type": "content_block",
          "settings": {
            "image_filename": "minimal_flatlay_sandstone.webp",
            "title": "Care and storage",
            "text": "<p>Before long-term storage, clean and fully dry the piece. Fill the bag with soft paper and keep it in a fabric dust bag.</p><p>Avoid plastic bags for long storage. Store detachable straps inside the bag.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I get a raffia or leather bag wet?",
            "answer": "No — leather and raffia pieces should not be exposed to moisture. If wet, blot with a dry cloth and let dry naturally."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How do I clean a leather bag?",
            "answer": "Use a soft cloth and leather care products. Test on a hidden area first, then wipe dry."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How should I store my bag?",
            "answer": "In a fabric dust bag, filled with soft paper to keep the shape, away from direct sun, high humidity and plastic bags."
          }
        }
      ]
    }
  ]
}
{% endschema %}
